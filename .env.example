# --- Twilio (appel réel à l'astreinte) ---------------------------------------
# Option A (recommandé) : API Key — console Twilio → API keys & tokens.
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
# Option B : Auth Token du compte.
# TWILIO_AUTH_TOKEN=
# Option C : connecteur Twilio de Lovable (si le projet tourne sur Lovable Cloud).
# LOVABLE_API_KEY=
# TWILIO_API_KEY=
# Autoriser POST /api/mayday/place-call (déclenchement d'appel par curl, coûte des crédits)
# ALLOW_CALL_API=1

# --- Vultr Serverless Inference (le cerveau agent, OpenAI-compatible) ----------
# Sans ces 3 variables → le cerveau tourne en "local reasoning" (décision déterministe),
# mais le retrieval BM25 sur docs-corpus reste RÉEL. Avec elles → vraie inférence LLM.
VULTR_INFERENCE_URL=https://api.vultrinference.com/v1
VULTR_INFERENCE_KEY=
VULTR_INFERENCE_MODEL=llama-3.3-70b-instruct-fp8

# --- Gradium (voix TTS + STT réelles, docs.gradium.ai) -------------------------
# Sans clé → fallback automatique Polly (Twilio <Say>/<Gather>).
GRADIUM_API_KEY=
# Voix anglaise par défaut : Emma. Autres EN: Kent LFZvm12tW_z0xfGo, John KWJiFWu2O9nMPYcR
GRADIUM_VOICE_ID=YTpq7expH9539ERJ
# Ne changer que pour les tests (mock) :
# GRADIUM_API_BASE=https://api.gradium.ai

# Les numéros To (votre téléphone) et From (numéro Twilio) se saisissent dans
# l'UI (bouton CONFIG) — pas besoin d'env pour ça.

# --- VM Vultr (shop live) -----------------------------------------------------
# L'URL de la VM se saisit aussi dans CONFIG (défaut: http://192.248.185.175).
# Token optionnel si le vm-shop est lancé avec ADMIN_TOKEN=...
