# --- Twilio (appel réel à l'astreinte) ---------------------------------------
# Option A (recommandé) : clés directes Twilio — console Twilio → Account Info.
# Requises aussi pour télécharger les enregistrements (flux Gradium STT).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Option B : connecteur Twilio de Lovable (si le projet tourne sur Lovable Cloud).
LOVABLE_API_KEY=
TWILIO_API_KEY=

# --- Gradium (voix TTS + STT réelles, docs.gradium.ai) -------------------------
# Sans clé → fallback automatique Polly (Twilio <Say>/<Gather>).
GRADIUM_API_KEY=
# Voix française par défaut : Elise. Autres : Leo axlOaUiFyOZhy4nv, Olivier vMYQUSzm6GRkJX6d
GRADIUM_VOICE_ID=b35yykvVppLXyw_l
# Ne changer que pour les tests (mock) :
# GRADIUM_API_BASE=https://api.gradium.ai

# Les numéros To (votre téléphone) et From (numéro Twilio) se saisissent dans
# l'UI (bouton CONFIG) — pas besoin d'env pour ça.

# --- VM Vultr (shop live) -----------------------------------------------------
# L'URL de la VM se saisit aussi dans CONFIG (défaut: http://192.248.185.175).
# Token optionnel si le vm-shop est lancé avec ADMIN_TOKEN=...
